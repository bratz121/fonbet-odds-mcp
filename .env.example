# Fonbet line API base URL. This is unofficial and can change.
FONBET_BASE_URL=https://line-lb51.bk6bba-resources.com

# Main events endpoint.
FONBET_CURRENT_LINE_PATH=/events/listBase

# Single event endpoint.
FONBET_EVENT_VIEW_PATH=/events/event

# Fonbet market scope. 1600 is commonly used by the web client.
FONBET_SCOPE_MARKET=1600

# Request timeout in seconds. The full line response is large.
FONBET_TIMEOUT=20

# MCP server mode. Use streamable-http for ChatGPT connector/tunnel.
MCP_TRANSPORT=streamable-http
MCP_HOST=127.0.0.1
MCP_PORT=8000
MCP_PATH=/mcp

